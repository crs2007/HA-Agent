# Immich version — leave as "release" to always pull the latest stable build
IMMICH_VERSION=release

# Root path for uploaded photos and videos (on the LXC's 640 GB disk)
UPLOAD_LOCATION=/opt/immich/photos

# PostgreSQL data directory (on the LXC's 640 GB disk)
DB_DATA_LOCATION=/opt/immich/postgres

# PostgreSQL credentials — change DB_PASSWORD to something strong
DB_USERNAME=immich
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_DATABASE_NAME=immich

# Port Immich listens on (2283 is the default)
IMMICH_PORT=2283

# Timezone
TZ=Asia/Jerusalem
